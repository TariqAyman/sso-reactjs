NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
NODE_ENV=development

# Authentication Configuration
NEXT_PUBLIC_AUTH_PROVIDERS=google,github,facebook,twitter,microsoft,nafath

# Nafath Configuration
NEXT_PUBLIC_NAFATH_ENABLED=true
NAFATH_MOCK_MODE=true
NEXT_PUBLIC_NAFATH_SERVICE_ID=your_service_id

# Social Authentication
NEXT_PUBLIC_GOOGLE_AUTH_ENABLED=true
NEXT_PUBLIC_GITHUB_AUTH_ENABLED=true
NEXT_PUBLIC_FACEBOOK_AUTH_ENABLED=true
NEXT_PUBLIC_TWITTER_AUTH_ENABLED=true
NEXT_PUBLIC_MICROSOFT_AUTH_ENABLED=true

# OAuth Configuration
NEXT_PUBLIC_OAUTH_CLIENT_ID=your_oauth_client_id
NEXT_PUBLIC_OAUTH_REDIRECT_URI=http://localhost:3000/oauth/callback

# API Configuration
NEXT_PUBLIC_API_TIMEOUT=10000
NEXT_PUBLIC_REQUEST_RETRY_COUNT=3
